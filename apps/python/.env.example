STAGE=dev
AWS_REGION=us-east-1
LOG_LEVEL=INFO

# Credentials come from SSM Parameter Store, the same as the deployed Lambda:
# the handler reads each parameter below, then falls back per-value to the env
# vars for anything it can't fetch. `serverless invoke local` therefore needs
# AWS creds that can call ssm:GetParameter (or rely on the env-var fallback).
# Parameter names must not start with "aws"/"ssm" (reserved by SSM).
TELEGRAM_BOT_TOKEN_PARAM=/automation/dev/telegram/bot-token
TELEGRAM_CHAT_ID_PARAM=/automation/dev/telegram/chat-id
TELEGRAM_BOT_TOKEN=123456789:replace-me
TELEGRAM_CHAT_ID=123456789
FREE_TIER_WARN_PERCENT=10
FREE_TIER_REPORT_MAX_ITEMS=3

# Domain that resolves to the reserved Elastic IP; used to look up the
# EC2 instance ID at runtime (start_instances/stop_instances require an
# instance ID, not an IP or domain).
EC2_DOMAIN=quickrecall-aws.duckdns.org
