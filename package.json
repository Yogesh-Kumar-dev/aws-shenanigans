{
  "name": "aws-shenanigans",
  "version": "0.1.0",
  "private": true,
  "description": "A multi-runtime AWS Serverless playground (Python + Node.js)",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "deploy:python": "pnpm --filter @aws-shenanigans/python run deploy",
    "deploy:node": "pnpm --filter @aws-shenanigans/node run deploy",
    "deploy:all": "pnpm -r run deploy",
    "remove:python": "pnpm --filter @aws-shenanigans/python run remove",
    "remove:node": "pnpm --filter @aws-shenanigans/node run remove"
  }
}
