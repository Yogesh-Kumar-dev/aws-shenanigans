STAGE=dev
AWS_REGION=us-east-1
LOG_LEVEL=INFO

# Credentials come from SSM Parameter Store, the same as the deployed Lambda:
# the handler reads the parameter named below, then falls back per-key to the
# env vars for anything it doesn't find. `serverless invoke local` therefore
# needs AWS creds that can call ssm:GetParameter.
#
# The parameter (defaults to /<service>/<stage>/telegram) holds JSON like:
#   {"TELEGRAM_BOT_TOKEN": "...", "TELEGRAM_CHAT_ID": "..."}
TELEGRAM_BOT_TOKEN_PARAM=/aws-automation/dev/telegram/bot-token
TELEGRAM_CHAT_ID_PARAM=/aws-automation/dev/telegram/chat-id
TELEGRAM_BOT_TOKEN=123456789:replace-me
TELEGRAM_CHAT_ID=123456789
FREE_TIER_WARN_PERCENT=10
FREE_TIER_REPORT_MAX_ITEMS=3
